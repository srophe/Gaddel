                      <cell role="data">http://syriaca.org/taxonomy/sadducees</cell>
                      <cell role="data">Sadducees</cell>
                    </row>
                    <row role="data">
                      <cell role="data">http://syriaca.org/taxonomy/samaritans</cell>
                      <cell role="data">Samaritans</cell>
                    </row>
                    <row role="data">
                      <cell role="data">http://syriaca.org/taxonomy/shia</cell>
                      <cell role="data">Shia</cell>
                    </row>
                    <row role="data">
                      <cell role="data">http://syriaca.org/taxonomy/sunni</cell>
                      <cell role="data">Sunni</cell>
                    </row>
