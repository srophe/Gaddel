                      <cell role="data">http://syriaca.org/taxonomy/roman-catholics</cell>
                      <cell role="data">Roman Catholics</cell>
                    </row>
                    <row role="data">
                      <cell role="data">http://syriaca.org/taxonomy/rum-orthodox</cell>
                      <cell role="data">Rum Orthodox</cell>
                    </row>
                    <row role="data">
                      <cell role="data">http://syriaca.org/taxonomy/russian-orthodox</cell>
                      <cell role="data">Russian Orthodox</cell>
                    </row>
